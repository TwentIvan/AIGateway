run = "pip install -q -r requirements.txt && litellm --config config.yaml --host 0.0.0.0 --port $PORT"
entrypoint = "config.yaml"

[nix]
channel = "stable-24_11"

[deployment]
build = ["sh", "-c", "pip install -q -r requirements.txt"]
run = ["sh", "-c", "litellm --config config.yaml --host 0.0.0.0 --port $PORT"]

[agent]
expertMode = true
